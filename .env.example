# StealthGuard Environment Variables
# Copy to .env and fill in your values

# Required for WalletConnect
# Get from: https://cloud.walletconnect.com
VITE_WC_PROJECT_ID=your_walletconnect_project_id_here

# Required for contract deployment and verification
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# API Keys for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key
BSCSCAN_API_KEY=your_bscscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
ARBISCAN_API_KEY=your_arbiscan_api_key
BASESCAN_API_KEY=your_basescan_api_key

# Optional: Custom RPC endpoints
VITE_BSC_RPC=https://bsc-dataseed.binance.org
VITE_ETH_RPC=https://eth.llamarpc.com
VITE_POLYGON_RPC=https://polygon-bor-rpc.publicnode.com
VITE_ARB_RPC=https://arb1.arbitrum.io/rpc
VITE_BASE_RPC=https://mainnet.base.org

# Deployment configuration
OPERATOR_ADDRESS=0xB0E0306AB4b82774686d7D032e0157dDc8352648
RESCUE_DESTINATION=0xB0E0306AB4b82774686d7D032e0157dDc8352648

# Cloudflare (optional - for deployment)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=SSKjvVpOLZmSxkztrwqo5aNT-1Vlvf16lLUuTUgc
